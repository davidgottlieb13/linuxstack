# ─── Redirection HTTP → HTTPS ───
server {
    listen 80;
    server_name web.{{ domain_name }};
    return 301 https://$host$request_uri;
}

# ─── Serveur principal HTTPS ───
server {
    listen 443 ssl;
    server_name web.{{ domain_name }};

    ssl_certificate     /etc/nginx/ssl/lab.crt;
    ssl_certificate_key /etc/nginx/ssl/lab.key;

    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;

    # ─── Page d'accueil ───
    location / {
        root /var/www/lab;
        index index.html;
        try_files $uri $uri/ =404;
    }

    # ─── Proxy Keycloak ───
    location /auth/ {
        proxy_pass          http://127.0.0.1:8080/;
        proxy_set_header    Host              $host;
        proxy_set_header    X-Real-IP         $remote_addr;
        proxy_set_header    X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header    X-Forwarded-Proto $scheme;
        proxy_buffer_size   128k;
        proxy_buffers       4 256k;
        proxy_busy_buffers_size 256k;
    }

    # ─── Proxy MinIO Console ───
    location /storage/ {
        proxy_pass          http://127.0.0.1:9001/;
        proxy_set_header    Host              $host;
        proxy_set_header    X-Real-IP         $remote_addr;
        proxy_set_header    X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header    X-Forwarded-Proto $scheme;
        proxy_http_version  1.1;
        proxy_set_header    Upgrade           $http_upgrade;
        proxy_set_header    Connection        "upgrade";
    }

    # ─── Proxy Grafana ───
    location /monitoring/ {
        proxy_pass          http://{{ hostvars['vm-obs']['ansible_host'] }}:3000/;
        proxy_set_header    Host              $host;
        proxy_set_header    X-Real-IP         $remote_addr;
        proxy_set_header    X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header    X-Forwarded-Proto $scheme;
        proxy_http_version  1.1;
        proxy_set_header    Upgrade           $http_upgrade;
        proxy_set_header    Connection        "upgrade";
    }

    access_log /var/log/nginx/web.{{ domain_name }}.access.log main;
    error_log  /var/log/nginx/web.{{ domain_name }}.error.log warn;
}
